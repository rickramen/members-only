<%- include('partials/header', { user }) %>

<h1>Home</h1>

<% if (user) { %>
  <p>Logged in as: <%= user.email %></p>

  <a href="/auth/logout">Logout</a>

  <br><br>
  <a href="/messages/new">Create Message</a>

<% } else { %>
  <p>Not logged in</p>

  <a href="/auth/login">Login</a>
  <a href="/auth/signup">Sign up</a>
<% } %>

<%- include('partials/footer') %>